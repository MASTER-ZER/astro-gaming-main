# Supabase / PostgreSQL connection URLs
# Use the Transaction Pooler (port 6543) for the running application.
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10

# Use the Direct Connection (port 5432) for Drizzle migrations / drizzle-kit push.
DIRECT_DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Server port (Vercel ignores this and uses its own routing)
PORT=5000
NODE_ENV=development

# Google OAuth credentials (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# Telegram bot notifications (optional)
TELEGRAM_BOT_TOKEN=

# Admin fallback password (optional)
ADMIN_PASSWORD=

# Web Push VAPID keys (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
